# API del backend (producción: URL pública del servidor)
# VITE_API_URL=https://tu-backend.example.com

# WhatsApp cuando el backend no responde (reserva manual; default: wa.link del footer)
# VITE_BOOKING_WHATSAPP_URL=https://wa.link/xxyvs9

# Google OAuth (mismo Client ID que GOOGLE_CLIENT_ID en el backend)
# VITE_GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com

# Mercado Pago — Public Key (Credenciales de producción o prueba; NO el Access Token)
# Debe ser la misma cuenta/modo que MERCADOPAGO_ACCESS_TOKEN en el backend
# VITE_MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
