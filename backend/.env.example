PORT=4000

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=lion_barber

# JWT para sesiones (cambiar en producción)
JWT_SECRET=tu-clave-secreta-muy-segura

# Google OAuth: Client ID de tu aplicación web (Google Cloud Console → APIs y servicios → Credenciales)
# Mismo valor que VITE_GOOGLE_CLIENT_ID en el frontend
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com

# Admins: emails separados por coma que pueden acceder al dashboard
ADMIN_EMAIL=admin@ejemplo.com

# Mercado Pago: Access Token de la MISMA app y modo que el pago (TEST- = sandbox, APP_USR- = producción)
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxx
FRONTEND_URL=http://localhost:3000
API_PUBLIC_URL=https://tu-backend-publico.com

# WhatsApp (Twilio): para avisar al barbero cuando se confirma una seña
# El número destino se toma de barbers.whatsapp_phone (por barbero, formato +54911...)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_WHATSAPP_FROM=+14155238886

# Notificación gratis al celular de la barbería (Telegram Bot)
# Crear bot con @BotFather y obtener chat_id con @userinfobot o getUpdates
# TELEGRAM_BOT_TOKEN=123456789:ABCDEF...
# TELEGRAM_CHAT_ID=123456789

# Afip SDK (facturación electrónica): https://app.afipsdk.com — token + CUIT obligatorios
# AFIP_ACCESS_TOKEN=
# AFIP_CUIT=
# AFIP_PRODUCTION=false
# AFIP_PTO_VTA=1
# AFIP_CBTE_TIPO=6   Responsable inscripto IVA → Factura B (6). Monotributo → 11 (Factura C).
# AFIP_CONDICION_IVA_RECEPTOR_ID=5   Consumidor final (DocTipo 99); otro código si AFIP lo exige para tu caso.
# Cert/clave ARCA (PEM): rutas O variables (no mezclar ambos métodos)
# AFIP_CERT_PATH=./afip-keys/certificado.crt
# AFIP_KEY_PATH=./afip-keys/clave.key
# AFIP_CERT= / AFIP_KEY= → contenido del .crt y .key (abrir en editor y pegar PEM), NO la ruta al archivo
# AFIP_CERT=
# AFIP_KEY=